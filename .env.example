# Schottenhamel Wiesn-Monitor — Konfiguration
# Datei umbenennen zu ".env" und ausfüllen

# Telegram Bot-Token (von @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# Telegram Chat-ID (eigene User-ID oder Gruppen-ID)
# Eigene ID: @userinfobot starten und /start schicken
TELEGRAM_CHAT_ID=123456789

# Polling-Intervall in Sekunden (Standard: 480 = 8 Minuten)
POLL_INTERVAL_SECONDS=480
